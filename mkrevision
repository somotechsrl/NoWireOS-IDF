#!/bin/bash

# revdescr
rdescr="$*";
[ -z "$rdescr" ] && rdescr="$(date)"

comma=" "
cmdh=include/30-rpc-cmd.h
idsh=include/30-rpc-ids.h
echo "enum RPC_ids {" > $idsh
echo "char *RPC_cmd[] = {" > $cmdh
sort ZZZ_RPCList.txt | while read rpc_cmd; do
	rpc_cmd=$(sed 's/ //g' <<< $rpc_cmd)
	[ -z "$rpc_cmd" ] && continue;
	rpc_id=$(sed -e 's/[.]/_/g' -e 's/[|]//g' <<< $rpc_cmd)
	echo -e "${comma}$rpc_id" >> $idsh
	echo -e "${comma}\"$rpc_cmd\"" >> $cmdh
	comma=","
done 
echo -e "};" >> $idsh
echo -e "};" >> $cmdh

# updates to last revision
git add . -A
git commit -m "$rdescr" -a
git push

git pull
cat > include/revision.h << EOT
#define REVISION \"$(git describe --tags | tail -n 1)\"" 
#define REV_DATE \"$(git log -1 --format=%cd | tail -n 1)\"" 
dat=(git log -1 --format=%cd)
EOT

exit

# Generate command list
cmd_enum="NULL_COMMAND";
cmd_text="\"\"";
cmd_params="\"\"";
while IFS="=" read command params; do
	[ -z "$command" ] && continue
	cmd_enum="$cmd_enum,$(sed 's/ /_/g' <<< $command)"
	cmd_text="$cmd_text,\"$command\""	
	cmd_params="$cmd_params,\"$params\""	
	done < 00_comm.list
cmd_enum="$cmd_enum,UNKNOWN_COMMAND=1000"
cmd_text="$cmd_text,NULL"
cmd_params="$cmd_params,NULL"

# Extracts Opentherm Messages for map String<->id
oth_enum="NULL_COMMAND";
oth_text="\"\"";
grep 'case OpenThermMessageID' *OpenTherm*.ino > 00_opentherm.list
while IFS=":" read pfx none1 otid none2; do
	[ -z "$otid" ] && continue
	oth_enum="$oth_enum,OpenThermMessageID::$otid"
	oth_text="$oth_text,\"$otid\""	
	done < 00_opentherm.list
oth_enum="$oth_enum,UNKNOWN_OT=0xffff"
oth_text="$oth_text,NULL"

