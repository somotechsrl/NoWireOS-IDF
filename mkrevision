for fn in *.ino; do
	echo "extracting prototypes from  $fn..."
	echo "// ****************************" >> Revision.h
	echo "// $fn" >> Revision.h
	echo "// ****************************" >> Revision.h
	grep '[a-z0-9A-Z_]\+ [a-z0-9A-Z_*]\+ *([a-z0-9A-Z,*& _.]*) *{' $fn \
